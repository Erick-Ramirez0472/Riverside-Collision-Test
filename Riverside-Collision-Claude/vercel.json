{
  "version": 2,
  "builds": [
    {
      "src": "api/send-quote.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/send-quote",
      "dest": "/api/send-quote.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
